# Copie para .env e ajuste conforme necessário (docker compose lê automaticamente).

# Banco relacional (Postgres) — dados curtos + imagem de NPC (bytea)
DB_NAME=tatakai
DB_USER=postgres
DB_PASS=postgres

# MongoDB — ficha textual de NPC. Em dev local usa o container `mongo` do compose;
# em produção, aponte para o Atlas (URI com o nome do banco no path).
MONGO_URI=mongodb://mongo:27017/tatakai

# Segurança (defina um segredo forte em produção, mínimo 32 caracteres)
JWT_SECRET=change-this-secret-in-production-min-32-chars

# Portas publicadas no HOST (defaults evitam conflito com serviços locais)
DB_HOST_PORT=5433        # Postgres acessível em localhost:5433 (interno continua 5432)
BACKEND_HOST_PORT=8080
FRONTEND_HOST_PORT=3001

# URLs (o que o navegador usa). Se mudar BACKEND_HOST_PORT, ajuste estes também.
API_URL=http://localhost:8080
WS_URL=http://localhost:8080/ws
# Deve bater com FRONTEND_HOST_PORT (CORS do backend)
FRONTEND_URL=http://localhost:3001

# Schema: update sobe contra Postgres novo; validate em produção com migração
DDL_AUTO=update
